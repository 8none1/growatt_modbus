# Copy to secrets.yaml (git-ignored) and fill in.
# If you already run ESPHome with a shared secrets.yaml, these names match its defaults,
# so an existing dongle config just reuses them.
wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"
ap_password: "fallback-ap-password"        # >= 8 chars
# 32-byte base64 API encryption key. Generate one at https://esphome.io/components/api
# or with: openssl rand -base64 32
api_encryption_key: "base64-32-byte-key"
ota_password: "your-ota-password"
